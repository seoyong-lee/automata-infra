{
  "name": "automata-infra",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --ext .ts && eslint services/composition/fargate-renderer --ext .mjs",
    "lint:fix": "eslint . --ext .ts --fix && eslint services/composition/fargate-renderer --ext .mjs --fix",
    "check:service-boundaries": "ts-node scripts/service-boundary-guards.ts",
    "synth": "tsc && cdk synth -c @envFile=env/config.json",
    "diff": "tsc && cdk diff -c @envFile=env/config.json",
    "deploy": "tsc && cdk deploy -c @envFile=env/config.json",
    "test:admin:guards": "ts-node scripts/admin-guards-smoke.ts",
    "smoke:admin:graphql": "ts-node scripts/admin-graphql-smoke.ts",
    "test:generation": "node --test -r ts-node/register scripts/generation.test.ts",
    "test:fargate-render": "node --test -r ts-node/register scripts/fargate-render-smoke.test.ts",
    "migrate:scene-subtitles": "ts-node scripts/migrate-scene-subtitles.ts",
    "secrets:youtube-data-api": "ts-node scripts/put-youtube-data-api-secret.ts",
    "youtube-oauth:refresh-token": "ts-node scripts/youtube-oauth-refresh-token.ts",
    "clean": "rm -rf cdk.out cdk.out-ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1013.0",
    "@aws-sdk/client-dynamodb": "^3.1012.0",
    "@aws-sdk/client-ecs": "^3.1014.0",
    "@aws-sdk/client-lambda": "^3.1012.0",
    "@aws-sdk/client-s3": "^3.1012.0",
    "@aws-sdk/client-secrets-manager": "^3.1012.0",
    "@aws-sdk/client-sfn": "^3.1012.0",
    "@aws-sdk/client-sqs": "^3.1012.0",
    "@aws-sdk/client-transcribe": "^3.1019.0",
    "@aws-sdk/lib-dynamodb": "^3.1012.0",
    "@aws-sdk/s3-request-presigner": "3.1012.0",
    "aws-cdk-lib": "^2.219.0",
    "constructs": "^10.4.2",
    "googleapis": "^171.4.0",
    "music-metadata": "^11.12.3",
    "source-map-support": "^0.5.21",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "aws-cdk": "^2.219.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
