{
  "region": "ap-northeast-2",
  "projectPrefix": "automata-studio",
  "reviewUiDomain": "review.example.com",
  "adminCallbackUrls": [
    "https://www.automata.studio/auth/callback",
    "http://localhost:3001/auth/callback"
  ],
  "adminLogoutUrls": [
    "https://www.automata.studio/login",
    "http://localhost:3001/login"
  ],
  "adminUserPoolDomainPrefix": "automata-studio-admin-auth-v2",
  "enableAdminSignup": false,
  "workflowScheduleExpression": "rate(6 hours)",
  "workflowScheduleEnabled": false,
  "defaultContentId": "history-en",
  "defaultLanguage": "en",
  "enableFargateComposition": true,
  "byteplusImageSecretId": "automata-studio/byteplus-image",
  "byteplusVideoSecretId": "automata-studio/byteplus-video",
  "runwaySecretId": "automata-studio/runway",
  "openAiSecretId": "automata-studio/openai",
  "elevenLabsSecretId": "automata-studio/elevenlabs",
  "shotstackSecretId": "automata-studio/shotstack",
  "googleOAuthSecretId": "automata-studio/google-oauth-admin",
  "youtubeSecrets": {
    "saju-shorts-ko": "youtube-oauth-saju-shorts-ko",
    "tarot-ko": "youtube-oauth-tarot-ko"
  },
  "channelConfigs": {
    "saju-shorts-ko": {
      "youtubeAccountType": "personal",
      "autoPublishEnabled": true,
      "defaultVisibility": "public",
      "defaultCategoryId": 22
    },
    "tarot-ko": {
      "youtubeAccountType": "personal",
      "autoPublishEnabled": false,
      "defaultVisibility": "unlisted",
      "defaultCategoryId": 22
    }
  }
}
